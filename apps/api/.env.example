# API metadata
API_VERSION=3.0.0
API_PREFIX=/api/v3
LOG_LEVEL=INFO

# CORS (comma-separated)
ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# SQLite (default)
DATABASE_URL=sqlite:///./gastos.db

# PostgreSQL example
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/gastos
